{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "headers": [
    {
      "source": "/shared/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/sac-anti-vol", "destination": "/landings/free/ecommerce/sac-anti-vol/index.html" },
    { "source": "/task-flow", "destination": "/landings/free/saas/task-flow/index.html" },
    { "source": "/tech-summit-2025", "destination": "/landings/free/event/tech-summit-2025/index.html" },
    { "source": "/portfolio-minimal", "destination": "/landings/free/freestyle/portfolio-minimal/index.html" },
    { "source": "/cacao", "destination": "/landings/TEST/ecommerce/cacao/index.html" },
    { "source": "/argile", "destination": "/landings/TEST/freestyle/argile/index.html" },
    { "source": "/cafe-matin", "destination": "/landings/TEST/freestyle/cafe-matin/index.html" },
    { "source": "/fourchette", "destination": "/landings/PURST/freestyle/fourchette/index.html" },
    { "source": "/parasites-sante", "destination": "/landings/PURST/advertorial/parasites-sante/index.html" },
    { "source": "/solutions-sommeil", "destination": "/landings/PURST/advertorial/solutions-sommeil/index.html" },
    { "source": "/cardiovasculaire", "destination": "/landings/PURST/listicle/cardiovasculaire/index.html" },
    { "source": "/saaspocalypse", "destination": "/landings/PURST/advertorial/saaspocalypse/index.html" }
  ]
}
